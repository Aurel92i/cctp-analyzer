# =============================================================================
# CCTP Analyzer - Variables d'environnement
# Chardonnet Conseil
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs

# -----------------------------------------------------------------------------
# API OpenRouter (pour GPT-4)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-votre-cle-openrouter-ici

# Modèle à utiliser (optionnel, défaut: openai/gpt-4-turbo)
# Alternatives: openai/gpt-4, anthropic/claude-3-opus
OPENROUTER_MODEL=openai/gpt-4-turbo

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_ENV=production
SECRET_KEY=generez-une-cle-secrete-aleatoire-ici

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# Pour générer une clé secrète sécurisée :
# python -c "import secrets; print(secrets.token_hex(32))"
